# ─────────────────────────────────────────────
# Fluent Bit log output — never commit collected logs
# ─────────────────────────────────────────────
logs/*.jsonl
logs/*.log

# keep the directory itself
!logs/.gitkeep

# ─────────────────────────────────────────────
# OS
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────
# Editor
# ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─────────────────────────────────────────────
# Environment / secrets
# ─────────────────────────────────────────────
.env
.env.*
!.env.example

# ─────────────────────────────────────────────
# Go
# ─────────────────────────────────────────────
bin/
dist/
*.exe

# ─────────────────────────────────────────────
# Node.js
# ─────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*

# ─────────────────────────────────────────────
# .NET
# ─────────────────────────────────────────────
**/obj/
**/bin/
*.user
*.suo

# ─────────────────────────────────────────────
# Rust
# ─────────────────────────────────────────────
target/

# ─────────────────────────────────────────────
# Python (ml-training)
# ─────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
