{
  "ConnectionStrings": {
    "DefaultConnection": "Server=mysql;Port=3306;Database=payment_db;User=ecommerce;Password=ecommerce_pass;"
  },
  "Payment": {
    "MaxRetries": 3,
    "ProviderTimeoutMs": 4000,
    "SuccessRate": 0.75,
    "DeclineRate": 0.15
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Formatting.Compact"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ],
    "Enrich": ["FromLogContext"],
    "Properties": {
      "Service": "api-payment"
    }
  },
  "AllowedHosts": "*"
}
