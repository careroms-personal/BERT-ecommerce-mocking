{
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=customer_db;Username=ecommerce;Password=ecommerce_pass"
  },
  "Jwt": {
    "Secret": "ecommerce-mock-jwt-secret-change-in-prod-32chars",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Formatting.Compact"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": ["FromLogContext"],
    "Properties": {
      "Service": "api-customer"
    }
  },
  "AllowedHosts": "*"
}
